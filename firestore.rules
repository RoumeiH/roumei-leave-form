rules_version = '2';

// ============================================================
// Firestore 安全規則
// ------------------------------------------------------------
// 部署方式:Firebase 主控台 → Firestore Database → 「規則」分頁
// 把整段貼進去 → 發布(Publish)
//
// 規則說明:
// - 所有集合都需要「已登入」才能讀寫
// - 匿名登入不允許存取(必須用 email/password 登入)
// - 這樣任何人打開網址,沒登入就完全動不了資料
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // 判斷:是否為已登入且非匿名的使用者
    function isAdmin() {
      return request.auth != null
          && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // 系統設定:只有管理者可讀寫
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    // 草稿:只有管理者可讀寫
    match /drafts/{docId} {
      allow read, write: if isAdmin();
    }

    // 歷史記錄:只有管理者可讀寫
    match /forms/{docId} {
      allow read, write: if isAdmin();
    }

    // 其他一律禁止(未來要用再開)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
